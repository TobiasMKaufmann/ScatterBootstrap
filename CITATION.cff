version: 0.4.0
license: MIT
repository-code: "https://github.com/TobiasMKaufmann/ScatterBootstrap"
keywords:
  - small-angle scattering
  - SAXS
  - SANS
  - form factor
  - structure factor
  - bootstrap
  - uncertainty quantification
