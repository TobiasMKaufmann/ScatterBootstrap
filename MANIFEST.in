# Include C source files and headers (needed to build from an sdist)
recursive-include src/scatterbootstrap *.c *.h

# Include Python source files
include src/*.py

# Include documentation
include README.md
include LICENSE
include CHANGELOG.md
include CONTRIBUTING.md
include CODE_OF_CONDUCT.md
include CITATION.cff

# Include the test suite and JOSS paper sources
recursive-include tests *.py
recursive-include paper *.md *.bib

# Include configuration files
include requirements.txt
include setup.py
include pyproject.toml
include MANIFEST.in

# Include initial parameter files
include src/initial_params.json

# Exclude compiled files and cache
global-exclude *.pyc
global-exclude *.pyo
global-exclude *.so
global-exclude __pycache__
global-exclude .DS_Store
global-exclude build/*
global-exclude dist/*
global-exclude *.egg-info/*
