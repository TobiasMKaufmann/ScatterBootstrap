# Include C source files and headers
# Note: core_shell_cylinder directory was removed - models now under form_factor/

# Include Python source files
include src/*.py

# Include documentation
include README.md
include LICENSE
include CHANGELOG.md

# Include configuration files
include requirements.txt
include setup.py
include pyproject.toml
include MANIFEST.in

# Include initial parameter files
include src/initial_params.json

# Exclude compiled files and cache
global-exclude *.pyc
global-exclude *.pyo
global-exclude *.so
global-exclude __pycache__
global-exclude .DS_Store
global-exclude build/*
global-exclude dist/*
global-exclude *.egg-info/*
